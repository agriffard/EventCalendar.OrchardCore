{
  "name": "EventCalendarDemo",
  "displayName": "Event Calendar Demo",
  "description": "Sets up a demo site using TheTheme with the Event Calendar module enabled, the calendar as the homepage and sample events.",
  "author": "agriffard",
  "website": "https://github.com/agriffard/EventCalendar.OrchardCore",
  "version": "1.0.0",
  "issetuprecipe": true,
  "categories": [ "default" ],
  "tags": [ "events", "calendar", "demo" ],
  "steps": [
    {
      "name": "feature",
      "enable": [
        "OrchardCore.HomeRoute",
        "OrchardCore.Admin",
        "OrchardCore.Diagnostics",
        "OrchardCore.Settings",
        "OrchardCore.Recipes",
        "OrchardCore.Resources",
        "OrchardCore.Features",
        "OrchardCore.Roles",
        "OrchardCore.Users",
        "OrchardCore.Navigation",
        "OrchardCore.Themes",
        "OrchardCore.Contents",
        "OrchardCore.ContentTypes",
        "OrchardCore.Title",
        "OrchardCore.Html",
        "OrchardCore.Liquid",
        "OrchardCore.Widgets",
        "OrchardCore.Flows",
        "TheAdmin",
        "TheTheme",
        "OrchardCore.EventCalendar"
      ]
    },
    {
      "name": "themes",
      "admin": "TheAdmin",
      "site": "TheTheme"
    },
    {
      "name": "roles",
      "Roles": [
        {
          "Name": "Anonymous",
          "Description": "Anonymous role",
          "Permissions": [ "ViewContent" ]
        },
        {
          "Name": "Authenticated",
          "Description": "Authenticated role",
          "Permissions": [ "ViewContent" ]
        }
      ]
    },
    {
      "name": "settings",
      "HomeRoute": {
        "Action": "Index",
        "Controller": "Calendar",
        "Area": "OrchardCore.EventCalendar"
      }
    },
    {
      "name": "content",
      "data": [
        {
          "ContentItemId": "4ev3ntsamplec0ntentitem001",
          "ContentType": "Event",
          "DisplayText": "Team Standup",
