@model EventPartEditViewModel

<div class="row">
    <div class="mb-3 col-md-6">
        <label asp-for="StartUtc" class="form-label">@T["Start (UTC)"]</label>
        <input asp-for="StartUtc" type="datetime-local" class="form-control" />
        <span asp-validation-for="StartUtc"></span>
    </div>
    <div class="mb-3 col-md-6">
        <label asp-for="EndUtc" class="form-label">@T["End (UTC)"]</label>
        <input asp-for="EndUtc" type="datetime-local" class="form-control" />
        <span asp-validation-for="EndUtc"></span>
    </div>
</div>

<div class="mb-3">
    <div class="form-check">
        <input asp-for="AllDay" class="form-check-input" />
        <label asp-for="AllDay" class="form-check-label">@T["All day event"]</label>
    </div>
</div>

<div class="mb-3">
    <label asp-for="Location" class="form-label">@T["Location"]</label>
    <input asp-for="Location" class="form-control" />
</div>

<div class="mb-3">
    <label asp-for="Url" class="form-label">@T["Link"]</label>
    <input asp-for="Url" type="url" class="form-control" />
    <span class="hint">@T["Optional URL for more information (registration, venue, etc.)."]</span>
</div>

<div class="mb-3">
    <label asp-for="Description" class="form-label">@T["Description"]</label>
    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
    <span class="hint">@T["Optional HTML shown on the event page."]</span>
</div>
